---
import BaseLayout from '../astro/layouts/baseLayout.astro';
import Page from '../react/pages/breadcrumb';

const title = 'Breadcrumb';
const description =
  'A growing collection of breadcrumb components built with React and Fluent UI 2';
---

<BaseLayout title={title} description={description}>
  <Page title={title} description={description} client:load />
</BaseLayout>
